PORT=5001
ACCESS_TOKEN_SECRET=change_this_access_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_this_refresh_secret
REFRESH_TOKEN_EXPIRES_IN_REMEMBER=30d
REFRESH_TOKEN_EXPIRES_IN_SESSION=1d

# Backward compatibility (optional)
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=15m
BCRYPT_ROUNDS=10

# SMTP config for forgot password email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=25Zone <no-reply@25zone.vn>
